generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  OWNER
  ADMIN
}

enum MediaType {
  AUDIO
  VIDEO
}

enum AuditAction {
  PROGRAM_CREATED
  PROGRAM_UPDATED
  PROGRAM_DELETED
  SESSION_CREATED
  SESSION_UPDATED
  SESSION_DELETED
  SESSION_REORDERED
  BULK_IMPORT_CREATED
  UPLOAD_URL_REQUESTED
}

enum TargetEntity {
  PROGRAM
  SESSION
  BULK_IMPORT
  UPLOAD
}

enum BulkImportStatus {
  COMPLETED
  FAILED
}

model Creator {
  id        String   @id @default(cuid())
  name      String
  brandName String?

  users       User[]
  programs    Program[]
  sessions    Session[]
  bulkImports BulkImport[]
  auditLogs   AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("creators")
}

model User {
  id           String   @id @default(cuid())
  creatorId    String
  email        String   @unique
  passwordHash String
  role         UserRole @default(OWNER)

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  auditLogs AuditLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@map("users")
}

model Program {
  id          String  @id @default(cuid())
  creatorId   String
  title       String
  description String?
  coverImageUrl String?

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  sessions    Session[]
  bulkImports BulkImport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([creatorId, id])
  @@map("programs")
}

model Session {
  id             String    @id @default(cuid())
  creatorId      String
  programId      String
  title          String
  duration       Int
  position       Int
  instructorName String?
  tags           String[]  @default([])
  mediaType      MediaType?
  mediaUrl       String?
  thumbnailUrl   String?

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([creatorId])
  @@index([creatorId, programId])
  @@index([programId, position])
  @@map("sessions")
}

model BulkImport {
  id             String           @id @default(cuid())
  creatorId      String
  programId      String
  clientImportId String
  status         BulkImportStatus
  resultJson     Json

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([creatorId, clientImportId])
  @@index([creatorId])
  @@index([programId])
  @@map("bulk_imports")
}

model AuditLog {
  id           String       @id @default(cuid())
  creatorId    String
  actorId      String
  action       AuditAction
  targetEntity TargetEntity
  targetId     String?
  metadata     Json?

  creator Creator @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([creatorId])
  @@index([creatorId, createdAt])
  @@index([creatorId, action, createdAt])
  @@map("audit_logs")
}